@page "/posts/{Slug}"
@inherits PostBase

<main class="main-content">
    <div class="content-area">
        @if (Post == null)
        {
            @if (NotFound)
            {
                <PageTitle>Post Not Found</PageTitle>
                <div class="card">
                    <h1>Post Not Found</h1>
                    <p>Sorry, the post you are looking for does not exist.</p>
                </div>
            }
            else
            {
                <p>Loading...</p>
            }
        }
        else
        {
            <PageTitle>@Post.Title</PageTitle>
            <article class="card">
                @if (!string.IsNullOrEmpty(Post.Image))
                {
                    <img src="@Post.Image" alt="@Post.Title" class="post-hero-image" />
                }
                <h1>@Post.Title</h1>
                <div class="card-meta">@Post.PublishedDate.ToString("MMMM dd, yyyy")</div>
                <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 1rem 0;" />
                <div>
                    @((MarkupString)Post.Content)
                </div>
            </article>
        }
    </div>
    <Sidebar />
</main>

