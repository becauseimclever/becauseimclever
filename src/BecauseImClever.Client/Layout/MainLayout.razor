@inherits LayoutComponentBase
@using BecauseImClever.Application.Interfaces
@using BecauseImClever.Domain.Entities
@using BecauseImClever.Client.Components
@using BecauseImClever.Client.Services
@inject IThemeService ThemeService
@inject HttpClient Http
@inject NavigationManager Navigation
@inject EscapeRoomStateService EscapeRoomState
@implements IDisposable

<div class="layout-container">
    <!-- Header -->
    <header>
        <a href="" class="logo">&lt;BecauseImClever /&gt;</a>
        <nav>
            <ul>
                <li><a href="">Home</a></li>
                <li><a href="posts">Blog</a></li>
                <li><a href="projects">Projects</a></li>
                <li><a href="clock">Clock</a></li>
                <li><a href="experiments/escape-room">Experiments</a></li>
                <li><a href="about">About</a></li>
            </ul>
        </nav>
        <select class="theme-switch" @onchange="OnThemeChanged" value="@currentTheme?.Key">
            @foreach (var theme in availableThemes)
            {
                <option value="@theme.Key">@theme.DisplayName</option>
            }
        </select>
    </header>

    @Body

    <!-- Footer -->
    <footer>
        <p>&copy; 2025 BecauseImClever. Built with .NET 10 & Blazor. | <a href="/privacy">Privacy Policy</a>@if (!string.IsNullOrEmpty(appVersion)) { <text> | v@appVersion</text> }</p>
    </footer>

    <!-- Extension Warning Banner -->
    <ExtensionWarningBanner />

    <!-- Console Watcher -->
    <ConsoleWatcher IsEscapeRoomActive="@this.isOnEscapeRoom"
                    OnDevToolsDetected="this.HandleDevToolsDetected" />

    <!-- Consent Banner -->
    <ConsentBanner />
</div>

@code {
    private Theme? currentTheme;
    private IReadOnlyList<Theme> availableThemes = Array.Empty<Theme>();
    private string? appVersion;
    private bool isOnEscapeRoom;

    protected override async Task OnInitializedAsync()
    {
        availableThemes = ThemeService.GetAvailableThemes();
        currentTheme = await ThemeService.GetCurrentThemeAsync();
        await ThemeService.SetThemeAsync(currentTheme);

        this.isOnEscapeRoom = this.IsEscapeRoomRoute(this.Navigation.Uri);
        this.Navigation.LocationChanged += this.OnLocationChanged;

        try
        {
            var response = await Http.GetFromJsonAsync<VersionInfo>("api/version");
            appVersion = response?.Version;
        }
        catch (HttpRequestException)
        {
            // Version display is non-critical; silently ignore failures
        }
    }

    private record VersionInfo(string Version);

    private async Task OnThemeChanged(ChangeEventArgs e)
    {
        var selectedKey = e.Value?.ToString();
        currentTheme = Theme.FromKey(selectedKey);
        await ThemeService.SetThemeAsync(currentTheme);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        this.isOnEscapeRoom = this.IsEscapeRoomRoute(e.Location);
        this.InvokeAsync(this.StateHasChanged);
    }

    private bool IsEscapeRoomRoute(string uri)
        => uri.Contains("/experiments/escape-room", StringComparison.OrdinalIgnoreCase);

    private async Task HandleDevToolsDetected()
    {
        if (this.isOnEscapeRoom && this.EscapeRoomState.IsGameStarted && !this.EscapeRoomState.IsGameComplete)
        {
            this.EscapeRoomState.IncrementDevToolsOpenCount();
            await this.EscapeRoomState.SaveStateAsync();
        }
    }

    public void Dispose()
    {
        this.Navigation.LocationChanged -= this.OnLocationChanged;
    }
}
