@using BecauseImClever.Client.Models.EscapeRoom
@using BecauseImClever.Client.Services
@inject EscapeRoomStateService State

@if (State.IsPuzzleSolved("library-cipher"))
{
    <div class="cipher-solved">
        <p>✅ You already decoded the cipher! A brass key was hidden behind the book.</p>
    </div>
}
else
{
    <div class="cipher-puzzle">
        <p class="cipher-instructions">
            Use the <strong>cipher wheel</strong> to decode the secret message. Each letter in the encoded text maps to a different letter.
        </p>

        <div class="cipher-key">
            <div class="cipher-key-row">
                @for (var i = 0; i < 26; i++)
                {
                    <div class="cipher-key-pair">
                        <span class="cipher-key-from">@((char)('A' + i))</span>
                        <span class="cipher-key-arrow">↓</span>
                        <span class="cipher-key-to">@this.Params.CipherKey[i]</span>
                    </div>
                }
            </div>
        </div>

        <div class="cipher-encoded">
            <p class="cipher-label">Encoded message:</p>
            <p class="cipher-text">@this.Params.EncodedMessage</p>
        </div>

        <div class="cipher-answer">
            <label class="cipher-label" for="cipherInput">Your answer:</label>
            <input id="cipherInput"
                   class="cipher-input"
                   type="text"
                   @bind="this.answer"
                   @bind:event="onchange"
                   placeholder="Type the decoded message..." />
        </div>

        @if (this.showError)
        {
            <p class="cipher-error">That doesn't look right. Check the cipher wheel and try again!</p>
        }

        @if (this.showSuccess)
        {
            <p class="cipher-success">🎉 Correct! The bookshelf slides open, revealing a brass key!</p>
        }

        <button class="cipher-submit bob-btn" @onclick="this.CheckAnswer" disabled="@this.showSuccess">
            Decode
        </button>
    </div>
}

@code {
    private string answer = string.Empty;
    private bool showError;
    private bool showSuccess;

    /// <summary>Gets or sets the puzzle parameters generated by PuzzleRandomizer.</summary>
    [Parameter, EditorRequired]
    public LibraryPuzzleParams Params { get; set; } = default!;

    /// <summary>Gets or sets the callback invoked when the puzzle is solved.</summary>
    [Parameter]
    public EventCallback OnSolved { get; set; }

    private async Task CheckAnswer()
    {
        var isCorrect = string.Equals(this.answer.Trim(), this.Params.PlainMessage, StringComparison.OrdinalIgnoreCase);
        if (isCorrect)
        {
            this.showSuccess = true;
            this.showError = false;
            await this.OnSolved.InvokeAsync();
        }
        else
        {
            this.showError = true;
            this.showSuccess = false;
        }
    }
}
