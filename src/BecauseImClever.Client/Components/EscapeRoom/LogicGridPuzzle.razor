@using BecauseImClever.Client.Models.EscapeRoom
@using BecauseImClever.Client.Services
@inject EscapeRoomStateService State

@if (State.IsPuzzleSolved("study-logic"))
{
    <div class="logic-solved">
        <p>✅ You already solved the chalkboard puzzle! The code is: <strong>@this.Params.CodeDigits</strong></p>
    </div>
}
else
{
    <div class="logic-puzzle">
        <p class="logic-instructions">
            The chalkboard contains three equations. Solve each to find a digit of the <strong>secret code</strong>.
        </p>

        <div class="logic-chalkboard">
            @for (var i = 0; i < this.Params.CodeDigits.Length; i++)
            {
                var index = i;
                var digit = this.Params.CodeDigits[i] - '0';
                <div class="logic-equation">
                    <span class="logic-equation-text">@this.GetEquation(index, digit)</span>
                    <span class="logic-equation-equals">=</span>
                    <input class="logic-digit-input"
                           type="text"
                           maxlength="1"
                           @bind="this.answers[index]"
                           @bind:event="onchange"
                           placeholder="?" />
                </div>
            }
        </div>

        @if (this.showError)
        {
            <p class="logic-error">Not quite right. Check your equations and try again!</p>
        }

        @if (this.showSuccess)
        {
            <p class="logic-success">🎉 Correct! The chalkboard reveals a hidden code: <strong>@this.Params.CodeDigits</strong></p>
        }

        <button class="logic-submit bob-btn" @onclick="this.CheckAnswer" disabled="@this.showSuccess">
            Submit Code
        </button>
    </div>
}

@code {
    private readonly string[] answers = ["", "", ""];
    private bool showError;
    private bool showSuccess;

    /// <summary>Gets or sets the puzzle parameters generated by PuzzleRandomizer.</summary>
    [Parameter, EditorRequired]
    public StudyPuzzleParams Params { get; set; } = default!;

    /// <summary>Gets or sets the callback invoked when the puzzle is solved.</summary>
    [Parameter]
    public EventCallback OnSolved { get; set; }

    private string GetEquation(int position, int digit) => position switch
    {
        0 => $"{digit + 3} − 3",
        1 => $"{digit * 2} ÷ 2",
        2 => $"{digit + 5} − 5",
        _ => $"{digit}",
    };

    private async Task CheckAnswer()
    {
        var enteredCode = string.Concat(this.answers);
        var isCorrect = string.Equals(enteredCode, this.Params.CodeDigits, StringComparison.Ordinal);
        if (isCorrect)
        {
            this.showSuccess = true;
            this.showError = false;
            await this.OnSolved.InvokeAsync();
        }
        else
        {
            this.showError = true;
            this.showSuccess = false;
        }
    }
}
