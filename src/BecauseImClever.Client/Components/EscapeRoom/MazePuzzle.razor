@using BecauseImClever.Client.Models.EscapeRoom
@using BecauseImClever.Client.Services
@inject EscapeRoomStateService State

@if (State.IsPuzzleSolved("garden-maze"))
{
    <div class="maze-solved">
        <p>✅ You already navigated the hedge maze! The code is: <strong>@this.Params.CodeDigits</strong></p>
    </div>
}
else
{
    <div class="maze-puzzle">
        <p class="maze-instructions">
            Navigate the <strong>hedge maze</strong> from the top-left entrance to the bottom-right exit.
            Click adjacent cells to move. Reach the exit to reveal the code!
        </p>

        <div class="maze-grid" style="grid-template-columns: repeat(@this.Params.MazeSize, 1fr);">
            @for (var y = 0; y < this.Params.MazeSize; y++)
            {
                for (var x = 0; x < this.Params.MazeSize; x++)
                {
                    var row = y;
                    var col = x;
                    var isWall = this.Params.MazeWalls[row, col];
                    var isPlayer = row == this.playerRow && col == this.playerCol;
                    var isExit = row == this.Params.MazeSize - 1 && col == this.Params.MazeSize - 1;
                    var cellClass = "maze-cell";
                    if (isWall)
                    {
                        cellClass += " maze-wall";
                    }

                    if (isPlayer)
                    {
                        cellClass += " maze-player";
                    }

                    if (isExit)
                    {
                        cellClass += " maze-exit";
                    }

                    <div class="@cellClass" @onclick="() => this.MoveToCell(row, col)">
                        @if (isPlayer)
                        {
                            <span>🧑</span>
                        }
                        else if (isExit && !isWall)
                        {
                            <span>🚪</span>
                        }
                        else if (isWall)
                        {
                            <span>🌿</span>
                        }
                    </div>
                }
            }
        </div>

        @if (this.showSuccess)
        {
            <p class="maze-success">🎉 You escaped the maze! The hedges reveal a code: <strong>@this.Params.CodeDigits</strong></p>
        }
    </div>
}

@code {
    private int playerRow;
    private int playerCol;
    private bool showSuccess;

    /// <summary>Gets or sets the puzzle parameters generated by PuzzleRandomizer.</summary>
    [Parameter, EditorRequired]
    public GardenPuzzleParams Params { get; set; } = default!;

    /// <summary>Gets or sets the callback invoked when the puzzle is solved.</summary>
    [Parameter]
    public EventCallback OnSolved { get; set; }

    private async Task MoveToCell(int row, int col)
    {
        if (this.showSuccess)
        {
            return;
        }

        // Must be adjacent (Manhattan distance == 1)
        var distance = Math.Abs(row - this.playerRow) + Math.Abs(col - this.playerCol);
        if (distance != 1)
        {
            return;
        }

        // Can't move into a wall
        if (this.Params.MazeWalls[row, col])
        {
            return;
        }

        this.playerRow = row;
        this.playerCol = col;

        // Check if player reached the exit
        if (row == this.Params.MazeSize - 1 && col == this.Params.MazeSize - 1)
        {
            this.showSuccess = true;
            await this.OnSolved.InvokeAsync();
        }
    }
}
