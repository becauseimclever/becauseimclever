@using BecauseImClever.Client.Models.EscapeRoom
@using BecauseImClever.Client.Services
@inject EscapeRoomStateService State

@if (State.IsPuzzleSolved("kitchen-sequence"))
{
    <div class="sequence-solved">
        <p>✅ You already cooked the recipe! A garden key was hidden beneath the pot.</p>
    </div>
}
else
{
    <div class="sequence-puzzle">
        <p class="sequence-instructions">
            Follow the <strong>secret recipe</strong> — add the ingredients in the correct order!
        </p>

        <div class="sequence-ingredients">
            @foreach (var ingredient in this.Params.Ingredients)
            {
                <button class="sequence-ingredient bob-btn"
                        disabled="@this.selectedIngredients.Contains(ingredient)"
                        @onclick="() => this.SelectIngredient(ingredient)">
                    @ingredient
                </button>
            }
        </div>

        <div class="sequence-selected">
            <p class="sequence-label">Your order:</p>
            <div class="sequence-selected-list">
                @foreach (var item in this.selectedIngredients)
                {
                    <span class="sequence-selected-item">@item</span>
                }
                @if (this.selectedIngredients.Count == 0)
                {
                    <span class="sequence-placeholder">Click ingredients above to add them...</span>
                }
            </div>
        </div>

        @if (this.showError)
        {
            <p class="sequence-error">That's not the right order. Reset and try a different combination!</p>
        }

        @if (this.showSuccess)
        {
            <p class="sequence-success">🎉 Correct! The recipe sizzles with magic and reveals a garden key!</p>
        }

        <div class="sequence-buttons">
            <button class="sequence-reset bob-btn" @onclick="this.Reset">Reset</button>
            <button class="sequence-submit bob-btn"
                    @onclick="this.CheckAnswer"
                    disabled="@(this.showSuccess || this.selectedIngredients.Count != this.Params.CorrectSequence.Count)">
                Cook!
            </button>
        </div>
    </div>
}

@code {
    private readonly List<string> selectedIngredients = [];
    private bool showError;
    private bool showSuccess;

    /// <summary>Gets or sets the puzzle parameters generated by PuzzleRandomizer.</summary>
    [Parameter, EditorRequired]
    public KitchenPuzzleParams Params { get; set; } = default!;

    /// <summary>Gets or sets the callback invoked when the puzzle is solved.</summary>
    [Parameter]
    public EventCallback OnSolved { get; set; }

    private void SelectIngredient(string ingredient)
    {
        if (!this.selectedIngredients.Contains(ingredient))
        {
            this.selectedIngredients.Add(ingredient);
            this.showError = false;
        }
    }

    private void Reset()
    {
        this.selectedIngredients.Clear();
        this.showError = false;
    }

    private async Task CheckAnswer()
    {
        var isCorrect = this.selectedIngredients.SequenceEqual(this.Params.CorrectSequence);
        if (isCorrect)
        {
            this.showSuccess = true;
            this.showError = false;
            await this.OnSolved.InvokeAsync();
        }
        else
        {
            this.showError = true;
            this.showSuccess = false;
        }
    }
}
