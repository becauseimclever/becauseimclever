@using BecauseImClever.Client.Models.EscapeRoom
@using BecauseImClever.Client.Services
@inject EscapeRoomStateService State

@if (State.IsPuzzleSolved("foyer-sorting"))
{
    <div class="sorting-solved">
        <p>✅ You already sorted the picture frames! The doors are unlocked.</p>
    </div>
}
else
{
    <div class="sorting-puzzle">
        <p class="sorting-instructions">
            Arrange the picture frames in <strong>chronological order</strong> — earliest date at the top.
        </p>

        <div class="sorting-frames">
            @for (var i = 0; i < this.currentOrder.Count; i++)
            {
                var index = i;
                <div class="sorting-frame">
                    <div class="sorting-frame-controls">
                        <button class="sorting-move-up bob-btn"
                                disabled="@(index == 0)"
                                @onclick="() => this.MoveUp(index)"
                                title="Move up">▲</button>
                        <button class="sorting-move-down bob-btn"
                                disabled="@(index == this.currentOrder.Count - 1)"
                                @onclick="() => this.MoveDown(index)"
                                title="Move down">▼</button>
                    </div>
                    <div class="sorting-frame-content">
                        <span class="sorting-frame-icon">🖼️</span>
                        <span class="sorting-frame-date">@this.currentOrder[index].ToString("MMMM d, yyyy")</span>
                    </div>
                </div>
            }
        </div>

        @if (this.showError)
        {
            <p class="sorting-error">That's not quite right. Try rearranging the frames!</p>
        }

        @if (this.showSuccess)
        {
            <p class="sorting-success">🎉 Correct! The picture frames click into place and two doors swing open!</p>
        }

        <button class="sorting-submit bob-btn" @onclick="this.CheckAnswer" disabled="@this.showSuccess">
            Check Order
        </button>
    </div>
}

@code {
    private List<DateOnly> currentOrder = [];
    private bool showError;
    private bool showSuccess;

    /// <summary>Gets or sets the puzzle parameters generated by PuzzleRandomizer.</summary>
    [Parameter, EditorRequired]
    public FoyerPuzzleParams Params { get; set; } = default!;

    /// <summary>Gets or sets the callback invoked when the puzzle is solved.</summary>
    [Parameter]
    public EventCallback OnSolved { get; set; }

    protected override void OnParametersSet()
    {
        if (this.currentOrder.Count == 0)
        {
            this.currentOrder = [.. this.Params.Dates];
        }
    }

    private void MoveUp(int index)
    {
        if (index <= 0)
        {
            return;
        }

        (this.currentOrder[index - 1], this.currentOrder[index]) =
            (this.currentOrder[index], this.currentOrder[index - 1]);
        this.showError = false;
    }

    private void MoveDown(int index)
    {
        if (index >= this.currentOrder.Count - 1)
        {
            return;
        }

        (this.currentOrder[index], this.currentOrder[index + 1]) =
            (this.currentOrder[index + 1], this.currentOrder[index]);
        this.showError = false;
    }

    private async Task CheckAnswer()
    {
        var isCorrect = this.currentOrder.SequenceEqual(this.Params.CorrectOrder);
        if (isCorrect)
        {
            this.showSuccess = true;
            this.showError = false;
            await this.OnSolved.InvokeAsync();
        }
        else
        {
            this.showError = true;
            this.showSuccess = false;
        }
    }
}
