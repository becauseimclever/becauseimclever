@using BecauseImClever.Client.Models.EscapeRoom

<div class="clippy">
    <SpeechBubble IsVisible="@(!string.IsNullOrEmpty(HintText))"
                  Text="@(HintText ?? string.Empty)"
                  OnDismissed="OnHintDismissed" />
    <div class="clippy-sprite @GetPoseClass()" @onclick="OnClicked" title="Click for a hint!">
        <div class="clippy-icon"
             role="img"
             aria-label="Clippy"
             style="@GetSpriteStyle()"></div>
    </div>
</div>

@code {
    private const string SpriteSheetPath = "images/escape-room/Clippy%20pixel%20sprite%20.png";
    private const int Columns = 4;
    private const int Rows = 2;
    private const int CellSize = 256;

    /// <summary>Gets or sets the current Clippy pose.</summary>
    [Parameter, EditorRequired]
    public ClippyPose Pose { get; set; }

    /// <summary>Gets or sets the hint text to show in the speech bubble. Null or empty hides the bubble.</summary>
    [Parameter]
    public string? HintText { get; set; }

    /// <summary>Gets or sets the callback invoked when Clippy is clicked.</summary>
    [Parameter]
    public EventCallback OnClicked { get; set; }

    /// <summary>Gets or sets the callback invoked when the speech bubble is dismissed.</summary>
    [Parameter]
    public EventCallback OnHintDismissed { get; set; }

    private string GetPoseClass() => this.Pose switch
    {
        ClippyPose.Idle => "clippy-idle",
        ClippyPose.Thinking => "clippy-thinking",
        ClippyPose.Pointing => "clippy-pointing",
        ClippyPose.Celebrating => "clippy-celebrating",
        ClippyPose.Suspicious => "clippy-suspicious",
        _ => "clippy-idle",
    };

    private (int Col, int Row) GetSpriteCell() => this.Pose switch
    {
        ClippyPose.Idle => (0, 0),
        ClippyPose.Thinking => (1, 0),
        ClippyPose.Pointing => (2, 0),
        ClippyPose.Celebrating => (3, 0),
        ClippyPose.Suspicious => (0, 1),
        _ => (0, 0),
    };

    private string GetSpriteStyle()
    {
        var (col, row) = this.GetSpriteCell();
        var offsetX = col * CellSize;
        var offsetY = row * CellSize;
        return $"background-image: url('{SpriteSheetPath}'); background-position: -{offsetX}px -{offsetY}px; background-size: {CellSize * Columns}px auto;";
    }
}
