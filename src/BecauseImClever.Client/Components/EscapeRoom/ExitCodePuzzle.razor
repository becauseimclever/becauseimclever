@using BecauseImClever.Client.Models.EscapeRoom
@using BecauseImClever.Client.Services
@inject EscapeRoomStateService State

@if (State.IsPuzzleSolved("exit-code"))
{
    <div class="exit-solved">
        <p>✅ The door is open — you escaped the labyrinth!</p>
    </div>
}
else
{
    <div class="exit-puzzle">
        <p class="exit-instructions">
            Enter the <strong>6-digit combination</strong> to unlock the front door and escape!
            The code was hidden across the Study chalkboard and the Garden maze.
        </p>

        <div class="exit-lock">
            <div class="exit-digits">
                @for (var i = 0; i < 6; i++)
                {
                    var index = i;
                    <input class="exit-digit-input"
                           type="text"
                           maxlength="1"
                           @bind="this.digits[index]"
                           @bind:event="onchange"
                           placeholder="?" />
                }
            </div>
        </div>

        @if (this.showError)
        {
            <p class="exit-error">Wrong combination! The lock clicks but doesn't open.</p>
        }

        @if (this.showSuccess)
        {
            <p class="exit-success">🎉 The lock clicks open! You've escaped the labyrinth!</p>
        }

        <button class="exit-submit bob-btn" @onclick="this.CheckAnswer" disabled="@this.showSuccess">
            Unlock
        </button>
    </div>
}

@code {
    private readonly string[] digits = ["", "", "", "", "", ""];
    private bool showError;
    private bool showSuccess;

    /// <summary>Gets or sets the puzzle parameters generated by PuzzleRandomizer.</summary>
    [Parameter, EditorRequired]
    public ExitPuzzleParams Params { get; set; } = default!;

    /// <summary>Gets or sets the callback invoked when the puzzle is solved.</summary>
    [Parameter]
    public EventCallback OnSolved { get; set; }

    private async Task CheckAnswer()
    {
        var enteredCode = string.Concat(this.digits);
        var isCorrect = string.Equals(enteredCode, this.Params.ExitCode, StringComparison.Ordinal);
        if (isCorrect)
        {
            this.showSuccess = true;
            this.showError = false;
            await this.OnSolved.InvokeAsync();
        }
        else
        {
            this.showError = true;
            this.showSuccess = false;
        }
    }
}
